{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "model": "llama/qwen-3.5-4B-Q4_K_M",
  "provider": {
    "llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Llama.cpp (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen-3.5-4B-Q4_K_M": {
          "name": "Qwen 3.5 4B"
        }
      }
    }
  },
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "*": "ask",
