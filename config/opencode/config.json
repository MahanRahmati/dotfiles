{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "small_model": "llama/qwen-2.5-coder-1.5B-Instruct",
  "provider": {
    "llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Llama.cpp (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen-3.5-4B-Instruct": {
          "name": "Qwen 3.5 4B Instruct"
        },
        "qwen-3.5-4B-Thinking": {
          "name": "Qwen 3.5 4B Thinking"
        },
        "qwen-3.5-2B": {
          "name": "Qwen 3.5 2B"
        },
        "gemma-4-e2b": {
          "name": "Gemma 4 E2B"
        },
        "gemma-4-e4b": {
          "name": "Gemma 4 E4B"
        },
        "qwen-2.5-coder-1.5B-Instruct": {
          "name": "Qwen 2.5 Coder 1.5B"
        }
      }
    }
  },
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "*": "ask",
          "cargo clippy *": "allow",
          "cargo fmt *": "allow",
          "cargo test *": "allow",
          "cargo check *": "allow",
          "cargo update *": "allow",
          "cargo search *": "allow",
          "go run *": "allow",
          "go build *": "allow",
          "go test *": "allow",
          "go vet *": "allow",
          "sqlc generate *": "allow",
          "git *": "deny"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "bash": {
          "*": "ask",
          "cargo clippy *": "allow",
          "cargo fmt *": "allow",
          "cargo test *": "allow",
          "cargo check *": "allow",
          "cargo search *": "allow",
          "go run *": "allow",
          "go build *": "allow",
          "go test *": "allow",
          "go vet *": "allow",
          "sqlc generate *": "allow",
          "git *": "deny"
        },
        "skill": {
          "*": "allow"
        }
      }
    }
  },
  "share": "disabled",
  "autoupdate": false,
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "deny",
    "git *": "deny",
    "cargo clippy *": "allow",
    "cargo fmt *": "allow",
    "cargo test *": "allow",
    "cargo check *": "allow",
    "go run *": "allow",
    "go build *": "allow",
    "go test *": "allow",
    "go vet *": "allow",
    "sqlc generate *": "allow"
  }
}
