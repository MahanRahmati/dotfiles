          "cargo test *": "allow",
          "cargo check *": "allow",
          "cargo update *": "allow",
          "cargo search *": "allow",
          "go run *": "allow",
          "go build *": "allow",
          "go test *": "allow",
          "go vet *": "allow",
          "sqlc generate *": "allow",
          "git *": "deny"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "bash": {
          "*": "ask",
          "cargo clippy *": "allow",
          "cargo fmt *": "allow",
          "cargo test *": "allow",
          "cargo check *": "allow",
          "cargo search *": "allow",
          "go run *": "allow",
          "go build *": "allow",
          "go test *": "allow",
          "go vet *": "allow",
          "sqlc generate *": "allow",
          "git *": "deny"
        },
        "skill": {
          "*": "allow"
        }
      }
    }
  },
  "share": "disabled",
  "autoupdate": false,
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "deny",
    "git *": "deny",
    "cargo clippy *": "allow",
    "cargo fmt *": "allow",
    "cargo test *": "allow",
    "cargo check *": "allow",
    "go run *": "allow",
    "go build *": "allow",
